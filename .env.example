# SIM Masjid — Template Environment Variables
# Salin file ini menjadi .env.local dan isi dengan nilai yang sesuai.
# JANGAN PERNAH MENGUNGGAH FILE .env.local KE REPOSITORY GIT!

# URL Proyek Supabase Anda (Settings -> API -> Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Kunci Anonim Supabase (Settings -> API -> Anon public API Key)
# Aman digunakan di sisi browser client
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Kunci Service Role Supabase (Settings -> API -> service_role API Key)
# PENTING: JANGAN PERNAH menampilkan kunci ini di sisi client/browser (tanpa prefix NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# URL Aplikasi (untuk keperluan redirect Auth)
# Lokal: http://localhost:3000
# Produksi: https://nama-aplikasi-anda.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
